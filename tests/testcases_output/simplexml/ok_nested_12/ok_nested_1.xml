<unit name="ok_nested_1">
  <description><detailed>Testcase of classes nested in classes. This is a reworked version of code from Castle Game Engine.</detailed></description>
  <structure name="TRepoSoundEngine" name_with_generic="TRepoSoundEngine" type="class" visibility="published">
    <ancestor name="TSoundEngine" declaration="TSoundEngine" />
    <routine name="SetRepositoryUrl" type="procedure" declaration="procedure SetRepositoryUrl(const Value: String);" visibility="private">
    </routine>
    <routine name="RestartLoopingChannels" type="procedure" declaration="procedure RestartLoopingChannels;" visibility="private">
    </routine>
    <routine name="GetLoopingChannel" type="function" declaration="function GetLoopingChannel(const Index: Cardinal): TLoopingChannel;" visibility="private">
    </routine>
    <routine name="ContextOpenCore" type="procedure" declaration="procedure ContextOpenCore; override;" visibility="private">
    </routine>
    <routine name="AddSoundImportanceName" type="procedure" declaration="procedure AddSoundImportanceName(const Name: string; Importance: Integer);" visibility="private">
    </routine>
    <routine name="Create" type="constructor" declaration="constructor Create;" visibility="public">
    </routine>
    <routine name="Destroy" type="destructor" declaration="destructor Destroy; override;" visibility="public">
    </routine>
    <variable name="FSoundImportanceNames" declaration="var FSoundImportanceNames: TStringList;" visibility="private">
    </variable>
    <variable name="FSounds" declaration="FSounds: TSoundInfoList;" visibility="private">
      <description><detailed>A list of sounds used by your program. Each sound has a unique name, used to identify sound in the XML file and for SoundFromName function. At the beginning, this list always contains exactly one sound, empty. This is a special TSoundInfoBuffer that has Sound=nil and Name=''. It means &quot;no sound&quot; in many cases.</detailed></description>
    </variable>
    <variable name="FSoundGroups" declaration="FSoundGroups: TSoundGroupList;" visibility="private">
    </variable>
    <variable name="FRepositoryUrl" declaration="FRepositoryUrl: String;" visibility="private">
    </variable>
    <variable name="FLoopingChannels" declaration="FLoopingChannels: TLoopingChannelList;" visibility="private">
    </variable>
    <property name="SoundImportanceNames" indexdecl="" type="TStringList" reader="FSoundImportanceNames" writer="" default_in_class="False" default_value="" nodefault="False"   stored="" visibility="private">
    </property>
    <type name="TLoopingChannelList" declaration="TLoopingChannelList =  TObjectList&lt;TLoopingChannel&gt;;" visibility="private">
    </type>
    <structure name="TSoundGroup" name_with_generic="TSoundGroup" type="class" visibility="private">
      <ancestor name="TSoundInfoList" declaration="TSoundInfoList" />
      <variable name="Name" declaration="Name: string;" visibility="public">
        <description><detailed>Group name (including parent group names).</detailed></description>
      </variable>
      <variable name="Url" declaration="Url: String;" visibility="public">
        <description><detailed>Group URL. Absolute (including parent group URL parts). Always ends with slash.</detailed></description>
      </variable>
      <variable name="ParentGroup" declaration="ParentGroup: TSoundGroup;" visibility="public">
        <description><detailed>A parent group (one among FSoundGroups, or <code>Nil</code> if not in any group).</detailed></description>
      </variable>
    </structure>
    <structure name="TSoundGroupList" name_with_generic="TSoundGroupList" type="class" visibility="private">
      <ancestor name="TObjectList" declaration="TObjectList&lt;TSoundGroup&gt;" />
      <routine name="IndexOfName" type="function" declaration="function IndexOfName(const GroupName: String): Integer;" visibility="public">
        <description><detailed>Index of group with given TSoundGroup.Name, or -1 if not found.</detailed></description>
      </routine>
    </structure>
    <structure name="TSoundInfo" name_with_generic="TSoundInfo" type="class" visibility="private">
      <description><detailed>Sound that can be played -- actual sound with buffer, or an alias to it.</detailed></description>
      <ancestor name="TObject" declaration="TObject" />
      <routine name="ReadElement" type="procedure" declaration="procedure ReadElement(const Element: TDOMElement; const AParentGroup: TSoundGroup; const BaseUrl: String; const ASoundEngine: TRepoSoundEngine); virtual;" visibility="public">
        <description><detailed>Read a sound from XML element &lt;sound&gt; or &lt;alias&gt;.</detailed></description>
      </routine>
      <routine name="ResolveNames" type="procedure" declaration="procedure ResolveNames(const AllSounds: TSoundInfoList); virtual;" visibility="public">
        <description><detailed>Do some finalization once all sounds are known, and their names are known.</detailed></description>
      </routine>
      <routine name="FinalSound" type="function" declaration="function FinalSound(const RecursionDepth: Cardinal): TSoundInfoBuffer; virtual; abstract;" visibility="public">
        <description><detailed>Get the final TSoundInfoBuffer, resolving aliases.</detailed></description>
      </routine>
      <variable name="FOwningSoundEngine" declaration="FOwningSoundEngine: TSoundEngine;" visibility="strictprivate">
        <description><detailed>Although we only support one instance of TSoundEngine, in <code>SoundEngine</code>, but it seems more future-proof to store in TSoundInfo own reference to TSoundEngine. Automatically assigned in ReadElement.</detailed></description>
      </variable>
      <variable name="Name" declaration="Name: String;" visibility="public">
        <description><detailed>Unique sound name (including parent group names). Empty for the special sound stNone = nil.</detailed></description>
      </variable>
      <variable name="ShortName" declaration="ShortName: String;" visibility="public">
        <description><detailed>Like Name, but without parent group names. Unique within the ParentGroup (not necessarily unique among all sounds).</detailed></description>
      </variable>
      <variable name="ParentGroup" declaration="ParentGroup: TSoundGroup;" visibility="public">
        <description><detailed>A group (one among FSoundGroups, or <code>Nil</code> if not in any group).</detailed></description>
      </variable>
      <property name="OwningSoundEngine" indexdecl="" type="TSoundEngine" reader="FOwningSoundEngine" writer="" default_in_class="False" default_value="" nodefault="False"   stored="" visibility="strictprotected">
      </property>
    </structure>
    <structure name="TSoundInfoAlias" name_with_generic="TSoundInfoAlias" type="class" visibility="private">
      <description><detailed>Sound that can be played, as an alias to a number of other TSoundInfo instances (an alias may lead to another alias, that's OK, as long as eventually it resolves into actual sound name).</detailed></description>
      <ancestor name="TSoundInfo" declaration="TSoundInfo" />
      <routine name="Create" type="constructor" declaration="constructor Create;" visibility="public">
      </routine>
      <routine name="Destroy" type="destructor" declaration="destructor Destroy; override;" visibility="public">
      </routine>
      <routine name="ReadElement" type="procedure" declaration="procedure ReadElement(const Element: TDOMElement; const AParentGroup: TSoundGroup; const BaseUrl: String; const ASoundEngine: TRepoSoundEngine); override;" visibility="public">
      </routine>
      <routine name="ResolveNames" type="procedure" declaration="procedure ResolveNames(const AllSounds: TSoundInfoList); override;" visibility="public">
      </routine>
      <routine name="FinalSound" type="function" declaration="function FinalSound(const RecursionDepth: Cardinal): TSoundInfoBuffer; override;" visibility="public">
      </routine>
      <variable name="Target" declaration="Target: TCastleStringList;" visibility="strictprivate">
      </variable>
    </structure>
    <structure name="TSoundInfoBuffer" name_with_generic="TSoundInfoBuffer" type="class" visibility="private">
      <description><detailed>Sound that can be played, with a buffer.</detailed></description>
      <ancestor name="TSoundInfo" declaration="TSoundInfo" />
      <routine name="ReadElement" type="procedure" declaration="procedure ReadElement(const Element: TDOMElement; const AParentGroup: TSoundGroup; const BaseUrl: String; const ASoundEngine: TRepoSoundEngine); override;" visibility="public">
      </routine>
      <routine name="FinalSound" type="function" declaration="function FinalSound(const RecursionDepth: Cardinal): TSoundInfoBuffer; override;" visibility="public">
      </routine>
      <routine name="Destroy" type="destructor" declaration="destructor Destroy; override;" visibility="public">
      </routine>
      <variable name="Sound" declaration="Sound: TCastleSound;" visibility="public">
      </variable>
    </structure>
    <structure name="TSoundInfoList" name_with_generic="TSoundInfoList" type="class" visibility="private">
      <description><detailed>List of TSoundInfo.</detailed></description>
      <ancestor name="TObjectList" declaration="TObjectList&lt;TSoundInfo&gt;" />
      <routine name="IndexOfName" type="function" declaration="function IndexOfName(const SoundName: String): Integer;" visibility="public">
        <description><detailed>Index of sound with given TSoundInfo.Name, or -1 if not found.</detailed></description>
      </routine>
    </structure>
  </structure>
</unit>
