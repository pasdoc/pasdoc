<unit name="ok_generic">
  <description><detailed>Tests of generics, both FPC and Delphi style.</detailed></description>
  <type name="TGeometryAttribsList2" declaration="TGeometryAttribsList2 = specialize TMyList&lt;TALBuffersCache&gt;;" visibility="published">
  </type>
  <structure name="TMyList" visibility="published" name_with_generic="generic TMyList&lt;T&gt;" type="class">
    <description><detailed>FPC generics tests -------------------------------------------------------</detailed></description>
    <ancestor name="TFPSList" declaration="TFPSList" />
    <routine name="Blah" declaration="function Blah: PT;" visibility="public" type="function">
    </routine>
  </structure>
  <structure name="TGeometryAttrib" visibility="published" name_with_generic="TGeometryAttrib" type="class">
    <ancestor name="TObject" declaration="TObject" />
    <variable name="Name" declaration="Name: string;" visibility="public">
    </variable>
    <variable name="AType" declaration="AType: TGeometryAttribType;" visibility="public">
    </variable>
    <variable name="Offset" declaration="Offset: Integer;" visibility="public">
    </variable>
  </structure>
  <structure name="TGeometryAttribsList" visibility="published" name_with_generic="TGeometryAttribsList" type="class">
    <description><detailed>You can also specialize and make a descendant at the same time.</detailed></description>
    <ancestor name="TMyList" declaration="specialize TMyList&lt;TGeometryAttrib&gt;" />
    <routine name="Find" declaration="function Find(const Name: string): TGeometryAttrib;" visibility="public" type="function">
    </routine>
  </structure>
  <structure name="TMyObject" visibility="published" name_with_generic="TMyObject" type="class">
    <description><detailed>A simple Test-Object</detailed></description>
    <ancestor name="TObject" declaration="TObject" />
  </structure>
  <structure name="TMyGenericList" visibility="published" name_with_generic="TMyGenericList" type="class">
    <ancestor name="TObjectList" declaration="TObjectList&lt;TMyObject&gt;" />
  </structure>
  <structure name="TMyNewGeneric" visibility="published" name_with_generic="TMyNewGeneric&lt;T1,T2&gt;" type="class">
    <ancestor name="TObject" declaration="TObject" />
    <routine name="Blah" declaration="function Blah: PT;" visibility="public" type="function">
    </routine>
  </structure>
  <structure name="TAnotherGenericType" visibility="published" name_with_generic="TAnotherGenericType" type="class">
    <description><detailed>Sample for a generic with more than one type. TPair is a Key-Value-Relation</detailed></description>
    <ancestor name="TDictionary" declaration="TDictionary&lt;TObject,TObject&gt;" />
  </structure>
  <structure name="TArray" visibility="published" name_with_generic="TArray" type="class">
    <description><detailed>All standard Generics:</detailed></description>
    <ancestor name="TObject" declaration="TObject" />
  </structure>
  <structure name="TEnumerator" visibility="published" name_with_generic="TEnumerator&lt;T&gt;" type="class">
    <ancestor name="TObject" declaration="TObject" />
  </structure>
  <structure name="TEnumerable" visibility="published" name_with_generic="TEnumerable&lt;T&gt;" type="class">
    <ancestor name="TObject" declaration="TObject" />
  </structure>
  <structure name="TList" visibility="published" name_with_generic="TList&lt;T&gt;" type="class">
    <ancestor name="TEnumerable" declaration="TEnumerable&lt;T&gt;" />
  </structure>
  <structure name="TQueue" visibility="published" name_with_generic="TQueue&lt;T&gt;" type="class">
    <ancestor name="TEnumerable" declaration="TEnumerable&lt;T&gt;" />
  </structure>
  <structure name="TStack" visibility="published" name_with_generic="TStack&lt;T&gt;" type="class">
    <ancestor name="TEnumerable" declaration="TEnumerable&lt;T&gt;" />
  </structure>
  <structure name="TPair" visibility="published" name_with_generic="TPair&lt;TKey,TValue&gt;" type="record">
  </structure>
  <structure name="TDictionary" visibility="published" name_with_generic="TDictionary&lt;TKey,TValue&gt;" type="class">
    <ancestor name="TEnumerable" declaration="TEnumerable&lt;TPair&lt;TKey,TValue&gt;&gt;" />
  </structure>
  <structure name="TObjectList" visibility="published" name_with_generic="TObjectList&lt;T:class&gt;" type="class">
    <ancestor name="TList" declaration="TList&lt;T&gt;" />
  </structure>
  <structure name="TObjectQueue" visibility="published" name_with_generic="TObjectQueue&lt;T:class&gt;" type="class">
    <ancestor name="TQueue" declaration="TQueue&lt;T&gt;" />
  </structure>
  <structure name="TObjectStack" visibility="published" name_with_generic="TObjectStack&lt;T:class&gt;" type="class">
    <ancestor name="TStack" declaration="TStack&lt;T&gt;" />
  </structure>
  <structure name="TObjectDictionary" visibility="published" name_with_generic="TObjectDictionary&lt;TKey,TValue&gt;" type="class">
    <ancestor name="TDictionary" declaration="TDictionary&lt;TKey,TValue&gt;" />
  </structure>
</unit>
